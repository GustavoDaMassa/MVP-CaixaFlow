<% content_for :title, "Dashboard" %>

<div class="dashboard">
  <h1>Dashboard</h1>

  <section class="dashboard-section">
    <h2>Faturamento</h2>
    <div class="revenue-grid">
      <div class="revenue-card">
        <span class="revenue-card__label">Hoje</span>
        <span class="revenue-card__value"><%= number_to_currency(@stats.revenue_today, unit: "R$", separator: ",", delimiter: ".") %></span>
      </div>
      <div class="revenue-card">
        <span class="revenue-card__label">Esta semana</span>
        <span class="revenue-card__value"><%= number_to_currency(@stats.revenue_this_week, unit: "R$", separator: ",", delimiter: ".") %></span>
      </div>
    </div>
  </section>

  <section class="dashboard-section">
    <h2>Pedidos por forma de pagamento hoje</h2>
    <div class="revenue-grid">
      <% Order.payment_methods.each_key do |method| %>
        <% total = @stats.revenue_by_payment_today[method] || 0 %>
        <div class="revenue-card">
          <span class="revenue-card__label"><%= Order::PAYMENT_LABELS[method] %></span>
          <span class="revenue-card__value"><%= number_to_currency(total, unit: "R$", separator: ",", delimiter: ".") %></span>
        </div>
      <% end %>
    </div>
  </section>

  <section class="dashboard-section">
    <h2>Últimos pedidos</h2>
    <% if @stats.recent_orders.empty? %>
      <p class="empty-state">Nenhum pedido ainda.</p>
    <% else %>
      <table class="table">
        <thead>
          <tr>
            <th>#</th>
            <th>Cliente</th>
            <th>Atendente</th>
            <th>Pagamento</th>
            <th>Total</th>
            <th>Data</th>
          </tr>
        </thead>
        <tbody>
          <% @stats.recent_orders.each do |order| %>
            <tr>
              <td><%= link_to "##{order.id}", order_path(order) %></td>
              <td><%= order.customer&.name || "Balcão" %></td>
              <td><%= order.user.name %></td>
              <td><%= Order::PAYMENT_LABELS[order.payment_method] %></td>
              <td><%= number_to_currency(order.total, unit: "R$", separator: ",", delimiter: ".") %></td>
              <td><%= l order.created_at, format: :short %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
  </section>
</div>
