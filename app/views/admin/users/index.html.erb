<% content_for :title, "Usuários" %>

<div class="page-header">
  <h1 class="page-title">Usuários</h1>
  <%= link_to "Novo usuário", new_admin_user_path, class: "btn btn-primary" %>
</div>

<div class="card">
  <table class="table">
    <thead>
      <tr>
        <th>Nome</th>
        <th>E-mail</th>
        <th>Perfil</th>
        <th>Status</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @users.each do |user| %>
        <tr>
          <td><%= user.name %></td>
          <td><%= user.email %></td>
          <td><%= user.role.humanize %></td>
          <td>
            <% if user.active? %>
              <span class="badge badge--delivered">Ativo</span>
            <% else %>
              <span class="badge badge--cancelled">Inativo</span>
            <% end %>
          </td>
          <td class="text-right">
            <%= link_to "Editar", edit_admin_user_path(user), class: "btn btn-sm btn-secondary" %>
            <% unless user.admin? %>
              <%= button_to "Remover", admin_user_path(user), method: :delete,
                    data: { turbo_confirm: "Remover #{user.name}?" },
                    class: "btn btn-sm btn-danger" %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
