<% content_for :title, "Categorias" %>

<div class="page-header">
  <h1 class="page-title">Categorias</h1>
  <% if current_user.admin? %>
    <%= link_to "Nova categoria", new_category_path, class: "btn btn-primary" %>
  <% end %>
</div>

<div class="card">
  <% if @categories.empty? %>
    <div class="empty-state"><p>Nenhuma categoria cadastrada.</p></div>
  <% else %>
    <div class="table-wrapper">
      <table class="table">
        <thead>
          <tr>
            <th>Nome</th>
            <% if current_user.admin? %><th></th><% end %>
          </tr>
        </thead>
        <tbody>
          <% @categories.each do |category| %>
            <tr>
              <td><%= category.name %></td>
              <% if current_user.admin? %>
                <td class="actions">
                  <%= link_to "Editar", edit_category_path(category), class: "btn btn-sm btn-secondary" %>
                  <%= button_to "Excluir", category_path(category), method: :delete,
                        data: { turbo_confirm: "Excluir \"#{category.name}\"?" },
                        class: "btn btn-sm btn-danger" %>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
