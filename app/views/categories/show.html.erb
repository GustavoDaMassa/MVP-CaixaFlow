<% content_for :title, @category.name %>
<div class="page-header">
  <h1 class="page-title"><%= @category.name %></h1>
  <% if current_user.admin? %>
    <%= link_to "Editar", edit_category_path(@category), class: "btn btn-secondary" %>
  <% end %>
</div>
<%= link_to "← Categorias", categories_path, class: "btn btn-link" %>