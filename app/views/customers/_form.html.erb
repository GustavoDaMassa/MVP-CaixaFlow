<%= form_with model: customer do |f| %>
  <%= render "shared/errors", object: customer %>
  <div class="form-section">
    <div class="form-group">
      <%= f.label :name, "Nome" %>
      <%= f.text_field :name, class: "form-control", autofocus: true %>
    </div>
    <div class="form-group">
      <%= f.label :phone, "Telefone" %>
      <%= f.text_field :phone, class: "form-control", placeholder: "(62) 99999-9999" %>
    </div>
    <div class="form-group">
      <%= f.label :email, "E-mail" %>
      <%= f.email_field :email, class: "form-control" %>
      <p class="form-hint">Usado para notificações de pedido.</p>
    </div>
    <div class="form-group">
      <%= f.label :address, "Endereço" %>
      <%= f.text_field :address, class: "form-control" %>
    </div>
    <div class="form-group">
      <%= f.label :notes, "Observações" %>
      <%= f.text_area :notes, class: "form-control" %>
    </div>
    <div class="form-actions">
      <%= f.submit customer.persisted? ? "Salvar alterações" : "Cadastrar cliente", class: "btn btn-primary" %>
      <%= link_to "Cancelar", customers_path, class: "btn btn-secondary" %>
    </div>
  </div>
<% end %>
