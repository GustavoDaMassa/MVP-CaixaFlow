<% content_for :title, "Minha conta" %>

<div class="page-header">
  <h1 class="page-title">Minha conta</h1>
</div>

<div class="card card-body" style="max-width:480px">
  <%= form_for(resource, as: resource_name, url: registration_path(resource_name),
               html: { method: :put, data: { turbo: false } }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="form-group">
      <%= f.label :name, "Nome" %>
      <%= f.text_field :name, class: "form-control", autofocus: true %>
    </div>
    <div class="form-group">
      <%= f.label :email, "E-mail" %>
      <%= f.email_field :email, class: "form-control", autocomplete: "email" %>
    </div>
    <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
      <p class="form-hint">Aguardando confirmação para: <%= resource.unconfirmed_email %></p>
    <% end %>
    <div class="form-group">
      <%= f.label :password, "Nova senha" %>
      <span class="form-hint">deixe em branco para não alterar</span>
      <%= f.password_field :password, class: "form-control", autocomplete: "new-password" %>
    </div>
    <div class="form-group">
      <%= f.label :password_confirmation, "Confirmação da nova senha" %>
      <%= f.password_field :password_confirmation, class: "form-control", autocomplete: "new-password" %>
    </div>
    <div class="form-group">
      <%= f.label :current_password, "Senha atual" %>
      <span class="form-hint">necessária para confirmar as alterações</span>
      <%= f.password_field :current_password, class: "form-control", autocomplete: "current-password" %>
    </div>
    <div class="form-actions">
      <%= f.submit "Salvar alterações", class: "btn btn-primary" %>
      <%= link_to "Cancelar", :back, class: "btn btn-secondary" %>
    </div>
  <% end %>
</div>

<div class="card card-body" style="max-width:480px;margin-top:1.5rem;border-color:#fca5a5">
  <h3 style="font-size:.95rem;font-weight:600;margin-bottom:.75rem;color:var(--danger)">Zona de perigo</h3>
  <%= button_to "Cancelar minha conta", registration_path(resource_name),
        data: { turbo_confirm: "Tem certeza? Esta ação não pode ser desfeita." },
        method: :delete,
        class: "btn btn-danger btn-sm" %>
</div>
