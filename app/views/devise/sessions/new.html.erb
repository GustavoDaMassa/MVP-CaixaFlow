<% content_for :title, "Entrar" %>

<div class="pos-login-page">
  <div class="pos-login-terminal">
    <%= image_tag "caixaflow_logo_transparent.png", class: "pos-login-bg", alt: "" %>

    <div class="pos-login-card">
      <p class="pos-login-brand">CaixaFlow</p>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name),
                   html: { data: { turbo: false } }) do |f| %>
        <%= f.email_field    :email,    class: "form-control pos-input",
              placeholder: "E-mail", autofocus: true, autocomplete: "email" %>
        <%= f.password_field :password, class: "form-control pos-input",
              placeholder: "Senha", autocomplete: "current-password" %>
        <% if devise_mapping.rememberable? %>
          <label class="pos-check">
            <%= f.check_box :remember_me %>
            <span>Lembrar</span>
          </label>
        <% end %>
        <%= f.submit "Entrar", class: "btn btn-primary pos-submit" %>
      <% end %>
    </div>
  </div>

  <div class="pos-login-links">
    <%= render "devise/shared/links" %>
  </div>
</div>
