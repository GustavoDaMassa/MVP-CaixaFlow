<% content_for :title, "Entrar" %>

<div class="login-page">
  <div class="login-page__divider"></div>

  <div class="login-page__panel">
    <h1 class="login-page__title">CaixaFlow</h1>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name),
                 html: { data: { turbo: false }, class: "login-form" }) do |f| %>

      <div class="login-form__group">
        <%= f.label :email, "E-mail", class: "login-form__label" %>
        <div class="login-form__input-wrap">
          <svg class="login-form__icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="2" y="5" width="16" height="12" rx="2"/>
            <path d="M2 7l8 5 8-5"/>
          </svg>
          <%= f.email_field :email, class: "login-form__input", placeholder: "seu@email.com",
                autofocus: true, autocomplete: "email" %>
        </div>
      </div>

      <div class="login-form__group">
        <%= f.label :password, "Senha", class: "login-form__label" %>
        <div class="login-form__input-wrap">
          <svg class="login-form__icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="3" y="9" width="14" height="10" rx="2"/>
            <path d="M7 9V6a3 3 0 016 0v3"/>
          </svg>
          <%= f.password_field :password, class: "login-form__input", placeholder: "••••••••",
                autocomplete: "current-password" %>
        </div>
      </div>

      <div class="login-form__meta">
        <% if devise_mapping.rememberable? %>
          <label class="login-form__remember">
            <%= f.check_box :remember_me %> Lembrar de mim
          </label>
        <% end %>
        <%= link_to "Esqueceu sua senha?", new_password_path(resource_name), class: "login-form__forgot" %>
      </div>

      <%= f.submit "Entrar →", class: "login-form__submit" %>
    <% end %>
  </div>
</div>
