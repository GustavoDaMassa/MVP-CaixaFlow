<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <title><%= content_for(:title) || "CaixaFlow" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if user_signed_in? %>
      <nav class="topnav" data-controller="nav">
        <span class="topnav__brand">CaixaFlow</span>
        <button class="topnav__hamburger" data-action="nav#toggle" aria-label="Menu">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
            <line x1="3" y1="6"  x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
        <ul class="topnav__links" data-action="click->nav#close">
          <li><%= link_to "Pedidos",    orders_path,           class: active_nav_class("orders") %></li>
          <li><%= link_to "Clientes",   customers_path,        class: active_nav_class("customers") %></li>
          <li><%= link_to "Produtos",   products_path,         class: active_nav_class("products") %></li>
          <li><%= link_to "Categorias", categories_path,       class: active_nav_class("categories") %></li>
          <li><%= link_to "Caixa",      cash_registers_path,   class: active_nav_class("cash_registers") %></li>
          <% if current_user.admin? %>
            <li><%= link_to "Dashboard",   admin_root_path,            class: active_nav_class("admin") %></li>
            <li><%= link_to "Usuários",    admin_users_path,           class: active_nav_class("admin/users") %></li>
            <li><%= link_to "Fiscal",      fiscal_configuration_path,  class: active_nav_class("fiscal_configuration") %></li>
          <% end %>
        </ul>
        <div class="topnav__user">
          <% if CashRegister.current %>
            <%= link_to "● Caixa aberto", cash_registers_path,
                  style: "color:#86efac;font-size:.8rem;font-weight:600;text-decoration:none" %>
          <% else %>
            <%= link_to "○ Caixa fechado", new_cash_register_path,
                  style: "color:rgba(255,255,255,.5);font-size:.8rem;text-decoration:none" %>
          <% end %>
          <span class="topnav__username"><%= current_user.name %></span>
          <%= button_to "Sair", destroy_user_session_path, method: :delete, class: "btn btn-sm btn-secondary" %>
        </div>
      </nav>
    <% end %>

    <div class="app-body">
      <% if notice.present? %>
        <div class="flash flash--notice"><%= notice %></div>
      <% end %>
      <% if alert.present? %>
        <div class="flash flash--alert"><%= alert %></div>
      <% end %>

      <%= yield %>
    </div>

    <footer class="app-footer">
      <div class="app-footer__inner">
        <%= image_tag "caixaflow_base.png", alt: "", class: "app-footer__logo" %>
      </div>
    </footer>
  </body>
</html>
