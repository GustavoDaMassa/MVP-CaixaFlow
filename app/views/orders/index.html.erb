<% content_for :title, "Pedidos" %>

<div class="page-header">
  <h1 class="page-title">Pedidos</h1>
  <%= link_to "Novo pedido", new_order_path, class: "btn btn-primary" %>
</div>

<div class="card">
  <div class="filter-bar">
    <%= search_form_for @q, html: { style: "display:contents" } do |f| %>
      <div class="form-group">
        <%= f.label :created_at_gteq, "A partir de" %>
        <%= f.date_field :created_at_gteq, class: "form-control" %>
      </div>
      <%= f.submit "Filtrar", class: "btn btn-secondary" %>
      <%= link_to "Limpar", orders_path, class: "btn btn-link" %>
    <% end %>
  </div>

  <% if @orders.empty? %>
    <div class="empty-state"><p>Nenhum pedido encontrado.</p></div>
  <% else %>
    <div class="table-wrapper">
      <table class="table">
        <thead>
          <tr>
            <th>#</th>
            <th>Cliente</th>
            <% if current_user.admin? %><th>Atendente</th><% end %>
            <th>Total</th>
            <th>Data</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @orders.each do |order| %>
            <tr>
              <td><%= link_to "##{order.id}", order_path(order) %></td>
              <td><%= order.customer&.name || "Balcão" %></td>
              <% if current_user.admin? %>
                <td class="text-muted"><%= order.user.name %></td>
              <% end %>
              <td><%= number_to_currency(order.total, unit: "R$", separator: ",", delimiter: ".") %></td>
              <td class="text-muted"><%= l order.created_at, format: :short %></td>
              <td class="actions">
                <%= link_to "Ver", order_path(order), class: "btn btn-sm btn-secondary" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <div class="pagination-wrapper"><%= paginate @orders %></div>
  <% end %>
</div>
