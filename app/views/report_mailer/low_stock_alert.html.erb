<h2>Alerta de estoque baixo</h2>

<p>Olá, <%= @admin.name %>. Os seguintes produtos estão abaixo do threshold mínimo:</p>

<table>
  <thead>
    <tr>
      <th>Produto</th>
      <th>Estoque atual</th>
      <th>Mínimo</th>
    </tr>
  </thead>
  <tbody>
    <% @products.each do |product| %>
      <tr>
        <td><%= product.name %></td>
        <td><%= product.stock %></td>
        <td><%= product.low_stock_threshold %></td>
      </tr>
    <% end %>
  </tbody>
</table>
